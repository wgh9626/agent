pipeline {
  agent {
    kubernetes {
      defaultContainer 'maven'
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
    - name: maven
      image: maven:3.9-eclipse-temurin-17
      command:
        - cat
      tty: true
    - name: kaniko
      image: martizih/kaniko:v1.27.1-debug
      command:
        - /bin/sh
        - -c
        - cat
      tty: true
    - name: git
      image: bitnami/git:latest
      command:
        - /bin/sh
        - -c
        - cat
      tty: true
'''
    }
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    ansiColor('xterm')
  }

  parameters {
    string(name: 'GIT_REF', defaultValue: 'main', description: 'Git branch/tag/commit')
  }

  environment {
    SERVICE_NAME = ''
    BUILD_PATH = '.'
    DOCKERFILE_PATH = './Dockerfile'
    IMAGE_REPO = ''
    IMAGE_TAG = ''
    IMAGE_TAG_STRATEGY = 'git-build-number'
    GITOPS_REPO = ''
    GITOPS_BRANCH = 'main'
    GITOPS_MANIFEST = ''
    HARBOR_CREDENTIALS_ID = 'harbor'
    GITOPS_GIT_CREDENTIALS_ID = 'gitops'
    ARGOCD_APP = ''
  }

  stages {
    stage('Checkout Source') {
      steps {
        checkout scm
        container('git') {
          sh '''
            git config --global --add safe.directory "${WORKSPACE}"
            git checkout "${GIT_REF}"
          '''
        }
      }
    }

    stage('Load Config') {
      steps {
        script {
          def configFile = 'demo-java-service/ci/release-config.yaml'
          if (!fileExists(configFile)) {
            error("Release config not found: ${configFile}")
          }

          def cfg = readYaml file: configFile
          echo "RAW cfg.service_name='${cfg.service_name}'"
          echo "RAW cfg.image_repo='${cfg.image_repo}'"
          echo "RAW cfg.gitops_repo='${cfg.gitops_repo}'"
          echo "RAW cfg.gitops_manifest='${cfg.gitops_manifest}'"
          echo "RAW cfg.argocd_app='${cfg.argocd_app}'"

          env.SERVICE_NAME = (cfg.service_name ?: '').toString()
          env.BUILD_PATH = (cfg.build_path ?: 'demo-java-service').toString()
          env.DOCKERFILE_PATH = (cfg.dockerfile_path ?: 'demo-java-service/Dockerfile').toString()
          env.IMAGE_REPO = (cfg.image_repo ?: '').toString()
          env.GITOPS_REPO = (cfg.gitops_repo ?: '').toString()
          env.GITOPS_BRANCH = (cfg.gitops_branch ?: 'main').toString()
          env.GITOPS_MANIFEST = (cfg.gitops_manifest ?: '').toString()
          env.ARGOCD_APP = (cfg.argocd_app ?: '').toString()
          env.IMAGE_TAG_STRATEGY = (cfg.image_tag_strategy ?: 'git-build-number').toString()
          env.HARBOR_CREDENTIALS_ID = (cfg.harbor_credentials_id ?: 'harbor').toString()
          env.GITOPS_GIT_CREDENTIALS_ID = (cfg.gitops_git_credentials_id ?: 'gitops').toString()

          echo "ENV SERVICE_NAME='${env.SERVICE_NAME}'"
          echo "ENV IMAGE_REPO='${env.IMAGE_REPO}'"
          echo "ENV GITOPS_REPO='${env.GITOPS_REPO}'"
          echo "ENV GITOPS_MANIFEST='${env.GITOPS_MANIFEST}'"
          echo "ENV ARGOCD_APP='${env.ARGOCD_APP}'"

          container('git') {
            def shortSha = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
            if (env.IMAGE_TAG_STRATEGY == 'git-sha') {
              env.IMAGE_TAG = "git-${shortSha}"
            } else if (env.IMAGE_TAG_STRATEGY == 'git-build-number') {
              env.IMAGE_TAG = "git-${shortSha}-${env.BUILD_NUMBER}"
            } else {
              env.IMAGE_TAG = "build-${env.BUILD_NUMBER}"
            }
          }
        }
      }
    }

    stage('Validate Config') {
      steps {
        script {
          def required = [
            SERVICE_NAME    : env.SERVICE_NAME,
            IMAGE_REPO      : env.IMAGE_REPO,
            GITOPS_REPO     : env.GITOPS_REPO,
            GITOPS_MANIFEST : env.GITOPS_MANIFEST,
            ARGOCD_APP      : env.ARGOCD_APP
          ]

          required.each { key, value ->
            def rendered = value == null ? 'null' : value.toString()
            echo "CONFIG ${key}='${rendered}'"
            if (!rendered.trim() || rendered == 'null') {
              error("Missing required config: ${key}")
            }
          }
        }
      }
    }

    stage('Build Jar') {
      steps {
        container('maven') {
          sh 'mvn -f ${BUILD_PATH}/pom.xml clean package -DskipTests'
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          withCredentials([usernamePassword(credentialsId: env.HARBOR_CREDENTIALS_ID, usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASS')]) {
            sh '''
              mkdir -p /kaniko/.docker
              AUTH=$(printf "%s:%s" "$HARBOR_USER" "$HARBOR_PASS" | base64 | tr -d '\n')
              cat > /kaniko/.docker/config.json <<EOF_JSON
{
  "auths": {
    "acr-dh-registry.eu-central-1.cr.aliyuncs.com": {
      "auth": "$AUTH"
    }
  }
}
EOF_JSON

              /kaniko/executor \
                --context "${WORKSPACE}/${BUILD_PATH}" \
                --dockerfile "${WORKSPACE}/${DOCKERFILE_PATH}" \
                --destination "${IMAGE_REPO}:${IMAGE_TAG}"
            '''
          }
        }
      }
    }

    stage('Update GitOps Repo') {
      steps {
        container('git') {
          withCredentials([usernamePassword(credentialsId: env.GITOPS_GIT_CREDENTIALS_ID, usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
            sh '''
              rm -rf gitops-repo
              git clone -b "${GITOPS_BRANCH}" "https://${GIT_USER}:${GIT_PASS}@github.com/wgh9626/agent.git" gitops-repo
              cd gitops-repo
              chmod +x demo-java-service/ci/scripts/update_gitops_image.sh
              UPDATE_OUTPUT=$(demo-java-service/ci/scripts/update_gitops_image.sh "${GITOPS_MANIFEST}" "${IMAGE_REPO}" "${IMAGE_TAG}")
              echo "$UPDATE_OUTPUT"
              if echo "$UPDATE_OUTPUT" | grep -q 'No manifest change detected'; then
                echo 'No GitOps manifest change; skip commit and push'
                exit 0
              fi
              git config user.name "jenkins"
              git config user.email "jenkins@example.local"
              git add "${GITOPS_MANIFEST}"
              git diff --cached --quiet && {
                echo 'No staged changes; skip commit and push'
                exit 0
              }
              git commit -m "release(${SERVICE_NAME}): update image to ${IMAGE_TAG}"
              git push origin "${GITOPS_BRANCH}"
            '''
          }
        }
      }
    }

    stage('Wait for Argo CD Sync') {
      steps {
        container('git') {
          sh 'chmod +x demo-java-service/ci/scripts/check_argocd_app.sh && demo-java-service/ci/scripts/check_argocd_app.sh "${ARGOCD_APP}" 300'
        }
      }
    }
  }
}
