pipeline {
  agent {
    kubernetes {
      defaultContainer 'maven'
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
    - name: maven
      image: maven:3.9-eclipse-temurin-17
      command:
        - cat
      tty: true
    - name: kaniko
      image: martizih/kaniko:v1.27.1-debug
      command:
        - /bin/sh
        - -c
        - cat
      tty: true
    - name: git
      image: bitnami/git:latest
      command:
        - /bin/sh
        - -c
        - cat
      tty: true
'''
    }
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    ansiColor('xterm')
  }

  parameters {
    string(name: 'GIT_REF', defaultValue: 'main', description: 'Git branch/tag/commit')
  }

  environment {
    SERVICE_NAME = ''
    BUILD_PATH = '.'
    DOCKERFILE_PATH = './Dockerfile'
    IMAGE_REPO = ''
    IMAGE_TAG = ''
    IMAGE_TAG_STRATEGY = 'git-build-number'
    GITOPS_REPO = ''
    GITOPS_BRANCH = 'main'
    GITOPS_MANIFEST = ''
    HARBOR_CREDENTIALS_ID = 'harbor'
    GITOPS_GIT_CREDENTIALS_ID = 'gitops'
  }

  stages {
    stage('Checkout Source') {
      steps {
        checkout scm
        container('git') {
          sh '''
            git config --global --add safe.directory "${WORKSPACE}"
            git checkout "${GIT_REF}"
          '''
        }
      }
    }

    stage('Load Config') {
      steps {
        script {
          def configFile = 'demo-java-service/ci/release-config.yaml'
          if (!fileExists(configFile)) {
            error("Release config not found: ${configFile}")
          }

          def cfg = readYaml file: configFile
          def props = [
            SERVICE_NAME             : (cfg.service_name ?: '').toString(),
            BUILD_PATH               : (cfg.build_path ?: 'demo-java-service').toString(),
            DOCKERFILE_PATH          : (cfg.dockerfile_path ?: 'demo-java-service/Dockerfile').toString(),
            IMAGE_REPO               : (cfg.image_repo ?: '').toString(),
            GITOPS_REPO              : (cfg.gitops_repo ?: '').toString(),
            GITOPS_BRANCH            : (cfg.gitops_branch ?: 'main').toString(),
            GITOPS_MANIFEST          : (cfg.gitops_manifest ?: '').toString(),
            ARGOCD_APP               : (cfg.argocd_app ?: '').toString(),
            IMAGE_TAG_STRATEGY       : (cfg.image_tag_strategy ?: 'git-build-number').toString(),
            HARBOR_CREDENTIALS_ID    : (cfg.harbor_credentials_id ?: 'harbor').toString(),
            GITOPS_GIT_CREDENTIALS_ID: (cfg.gitops_git_credentials_id ?: 'gitops').toString()
          ]

          echo "RAW cfg.service_name='${cfg.service_name}'"
          echo "RAW cfg.image_repo='${cfg.image_repo}'"
          echo "RAW cfg.gitops_repo='${cfg.gitops_repo}'"
          echo "RAW cfg.gitops_manifest='${cfg.gitops_manifest}'"
          echo "RAW cfg.argocd_app='${cfg.argocd_app}'"

          container('git') {
            def shortSha = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
            if (props.IMAGE_TAG_STRATEGY == 'git-sha') {
              props.IMAGE_TAG = "git-${shortSha}"
            } else if (props.IMAGE_TAG_STRATEGY == 'git-build-number') {
              props.IMAGE_TAG = "git-${shortSha}-${env.BUILD_NUMBER}"
            } else {
              props.IMAGE_TAG = "build-${env.BUILD_NUMBER}"
            }
          }

          props.each { key, value ->
            echo "PROP ${key}='${value}'"
          }

          writeFile file: '.release-config.properties', text: props.collect { key, value ->
            "${key}=${value}"
          }.join('\n') + '\n'
        }
      }
    }

    stage('Validate Config') {
      steps {
        script {
          def cfg = readProperties file: '.release-config.properties'
          def required = [
            SERVICE_NAME    : cfg.SERVICE_NAME,
            IMAGE_REPO      : cfg.IMAGE_REPO,
            GITOPS_REPO     : cfg.GITOPS_REPO,
            GITOPS_MANIFEST : cfg.GITOPS_MANIFEST,
            ARGOCD_APP      : cfg.ARGOCD_APP
          ]

          required.each { key, value ->
            def rendered = value == null ? 'null' : value.toString()
            echo "CONFIG ${key}='${rendered}'"
            if (!rendered.trim() || rendered == 'null') {
              error("Missing required config: ${key}")
            }
          }
        }
      }
    }

    stage('Build Jar') {
      steps {
        container('maven') {
          script {
          def cfg = readProperties file: '.release-config.properties'
          sh "mvn -f ${cfg.BUILD_PATH}/pom.xml clean package -DskipTests"
        }
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          script {
            def cfg = readProperties file: '.release-config.properties'
            withCredentials([usernamePassword(credentialsId: cfg.HARBOR_CREDENTIALS_ID, usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASS')]) {
              sh """
                mkdir -p /kaniko/.docker
                AUTH=\$(printf \"%s:%s\" \"\$HARBOR_USER\" \"\$HARBOR_PASS\" | base64 | tr -d '\\n')
                cat > /kaniko/.docker/config.json <<EOF_JSON
{
  \"auths\": {
    \"acr-dh-registry.eu-central-1.cr.aliyuncs.com\": {
      \"auth\": \"\$AUTH\"
    }
  }
}
EOF_JSON

                /kaniko/executor \
                  --context \"${env.WORKSPACE}/${cfg.BUILD_PATH}\" \
                  --dockerfile \"${env.WORKSPACE}/${cfg.DOCKERFILE_PATH}\" \
                  --destination \"${cfg.IMAGE_REPO}:${cfg.IMAGE_TAG}\"
              """
            }
          }
        }
      }
    }

    stage('Update GitOps Repo') {
      steps {
        container('git') {
          script {
            def cfg = readProperties file: '.release-config.properties'
            withCredentials([usernamePassword(credentialsId: cfg.GITOPS_GIT_CREDENTIALS_ID, usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
              sh """
                rm -rf gitops-repo
                git clone -b \"${cfg.GITOPS_BRANCH}\" \"https://\$GIT_USER:\$GIT_PASS@github.com/wgh9626/agent.git\" gitops-repo
                cd gitops-repo
                chmod +x demo-java-service/ci/scripts/update_gitops_image.sh
                UPDATE_OUTPUT=\$(demo-java-service/ci/scripts/update_gitops_image.sh \"${cfg.GITOPS_MANIFEST}\" \"${cfg.IMAGE_REPO}\" \"${cfg.IMAGE_TAG}\")
                echo \"\$UPDATE_OUTPUT\"
                if echo \"\$UPDATE_OUTPUT\" | grep -q 'No manifest change detected'; then
                  echo 'No GitOps manifest change; skip commit and push'
                  exit 0
                fi
                git config user.name \"jenkins\"
                git config user.email \"jenkins@example.local\"
                git add \"${cfg.GITOPS_MANIFEST}\"
                git diff --cached --quiet && {
                  echo 'No staged changes; skip commit and push'
                  exit 0
                }
                git commit -m \"release(${cfg.SERVICE_NAME}): update image to ${cfg.IMAGE_TAG}\"
                git push origin \"${cfg.GITOPS_BRANCH}\"
              """
            }
          }
        }
      }
    }


  }
}
